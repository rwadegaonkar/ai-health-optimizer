# Database
DB_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://health_ai:${DB_PASSWORD}@db:5432/health_ai

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI (for food photo recognition)
OPENAI_API_KEY=sk-your-key-here

# Anthropic (alternative for food recognition)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Nutritionix API (food search + macros)
NUTRITIONIX_APP_ID=your-app-id
NUTRITIONIX_API_KEY=your-api-key

# Fitbit OAuth2
FITBIT_CLIENT_ID=your-client-id
FITBIT_CLIENT_SECRET=your-client-secret
FITBIT_REDIRECT_URI=http://localhost:8000/api/v1/integrations/fitbit/callback

# App
APP_NAME=AI Health Optimizer
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:3000
